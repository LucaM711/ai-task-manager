# ─────────────────────────────────────────────
#  AI Task Manager — Environment Configuration
#  Copia questo file in .env e adatta i valori.
#  Il file .env NON va mai committato.
# ─────────────────────────────────────────────

# ── MongoDB ──────────────────────────────────
# URI di connessione a MongoDB locale
MONGODB_URI=mongodb://localhost:27017

# Nome del database (usa un nome diverso per ambienti separati)
MONGODB_DB_NAME=ai_task_manager

# ── Ollama / LLM ─────────────────────────────
# URL base di Ollama (default: locale)
OLLAMA_BASE_URL=http://localhost:11434

# Modello da usare. Deve essere già scaricato con: ollama pull <nome>
OLLAMA_MODEL=qwen2.5:1.5b-Instruct

# Temperatura del modello (0.0 = deterministico, 1.0 = creativo)
# Valori bassi (0.1–0.3) migliorano l'affidabilità del tool calling
LLM_TEMPERATURE=0.2

# Finestra di contesto (token). 4096 copre prompt + 16 tool schemas + history
LLM_MAX_TOKENS=4096

# ── Applicazione ─────────────────────────────
APP_ENV=development
